---
import Header from '../components/Header';

import VideoBackground from '../components/VideoBackground';
import '../index.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { title = "muffin", description = "muffin's personal site — security, reverse engineering, and misc ramblings.", image = "/favicon.ico" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="canonical" href={canonicalURL} />
		<title>{title}</title>

		<!-- SEO -->
		<meta name="description" content={description} />
		<meta name="author" content="muffin" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- RSS -->
		<link rel="alternate" type="application/rss+xml" title="muffin's blog" href="/rss.xml" />
	</head>
	<body class="theme-image">
		<div id="root" class="app-container">

			<VideoBackground client:load />
			<div class="content-container">
				<Header client:load />
				<main>
					<slot />
				</main>
			</div>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--header-height: 72px;
	}
</style>
