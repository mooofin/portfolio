---
import BaseLayout from '../layouts/BaseLayout.astro';
import MatrixPage from "../components/MatrixPage.tsx";
---

<BaseLayout title="terminal | muffin">
    <style is:global>
      html, body { height: 100%; overflow: hidden; background: #000; padding: 0; margin: 0; }
    </style>

    <div class="single-screen-layout">
        <MatrixPage client:load />
    </div>
</BaseLayout>